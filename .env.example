# Supabase — copy to .env and fill with your project values
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Database password (Supabase → Project Settings → Database) — for npm run db:migrate only
# SUPABASE_DB_PASSWORD=your-database-password
# Or use a full connection string:
# DATABASE_URL=postgresql://postgres:...@db.your-project-ref.supabase.co:5432/postgres

VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Public site URL (canonical links, Open Graph — set in Vercel Production env)
VITE_SITE_URL=https://biswajitpowerhub.vercel.app
